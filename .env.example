# Postgres connection string. On Render, use the "Internal Database URL" from your Postgres instance.
DATABASE_URL=postgresql://user:password@localhost:5432/pipeline

# This app's own public URL — used to build absolute URLs it hands to
# third parties (Facebook's OAuth redirect_uri, Stripe's success/cancel
# URLs) and for its own login redirects. Deliberately NEVER inferred from
# the incoming request, because Render's reverse proxy exposes an internal
# service hostname to the app, not the public domain.
#
# Usually you don't need to set this: on Render, RENDER_EXTERNAL_URL is
# injected automatically with the correct https://*.onrender.com URL, no
# configuration needed. Only set APP_URL explicitly if you're serving from
# a custom domain, or hosting somewhere other than Render.
APP_URL=

# Random long secret used to sign session (access token) cookies. Generate with: openssl rand -base64 32
JWT_SECRET=

# 32-byte base64 key used to encrypt Facebook page access tokens at rest. Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# Set this to any random string, then use the same value when you register the
# webhook URL in your Facebook App's dashboard.
FACEBOOK_VERIFY_TOKEN=

# From your Facebook App's dashboard (Settings > Basic). Required for the
# "Connect with Facebook" OAuth flow (Facebook Login for Business).
# FACEBOOK_APP_SECRET is ALSO used to verify the X-Hub-Signature-256 HMAC on
# incoming leadgen webhooks — when it is set (as it must be for OAuth anyway),
# forged webhook deliveries are rejected. If unset, signature verification is
# skipped so local/dev delivery still works.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Shared secret for the auto-recycle cron endpoint (/api/cron/recycle-leads).
# Whatever external scheduler you use (Render Cron Job, cron-job.org, etc.)
# must send this exact value in an X-Cron-Secret header. Generate with: openssl rand -base64 32
CRON_SECRET=

# Which AI provider backs src/lib/ai (lead scoring, next-best-action, the
# assistant, etc). Defaults to "none" (a Noop stub — every AI feature stays
# functional but returns empty/neutral results) if unset. No AI provider is
# wired up yet, so leaving this blank is expected in every environment today.
AI_PROVIDER=

# Only read once, by `npm run db:seed`, to create the very first super_admin
# account. Defaults to admin@yourcompany.com / changeme123 if unset — set
# both before running the seed against a real deployment so the default
# credentials are never live anywhere reachable.
SEED_SUPER_ADMIN_EMAIL=
SEED_SUPER_ADMIN_PASSWORD=

# Stripe billing (see README.md's "Billing (Stripe)" section for full setup
# steps). Every company gets a 7-day free trial with no Stripe involvement
# at all; these are only needed once a company subscribes.

# Secret key from https://dashboard.stripe.com/apikeys (use a test key,
# sk_test_..., until you're ready to go live).
STRIPE_SECRET_KEY=

# Signing secret for the /api/webhooks/stripe endpoint, from either the
# Stripe CLI (`stripe listen`) in dev, or your webhook endpoint's settings
# page (https://dashboard.stripe.com/webhooks) in production.
STRIPE_WEBHOOK_SECRET=

# The Price ID (price_...) for the single monthly plan — create one Product
# with one recurring monthly Price in the Stripe Dashboard and paste its ID
# here. Only one plan is supported; there is no plan-picker.
STRIPE_PRICE_ID=

# --- Platform Owner Mailbox (super_admin only) ---
# Resend API key — used to SEND from support@/sales@/mail@ziplod.com. Without
# it, the mailbox is fully usable (compose, drafts, threading, search) but
# sending returns a clear "not configured" error instead of putting mail on
# the wire. Create the key at https://resend.com and verify the ziplod.com
# domain (DNS: SPF + DKIM records Resend gives you) so mail actually delivers.
RESEND_API_KEY=
# Shared secret for the inbound-email webhook. Set this, then in Resend
# configure inbound routing for your MX to POST to
# https://YOUR_DOMAIN/api/mailbox/inbound?secret=THIS_VALUE — that's how
# replies land back in the mailbox. Generate with: openssl rand -hex 24
MAILBOX_INBOUND_SECRET=

# Phase 12: set to "true" once you have configured off-provider backups
# (scripts/backup.mjs) so the Launch Checklist marks backups as ready.
BACKUP_ENABLED=

# --- Optional: everything below has a working default ---
# Listed so you know the knob exists; leaving them blank is fine.

# Envelope sender for transactional email (verification codes, password
# resets, agent invites). Must be on a domain you have verified with Resend,
# or those mails will not deliver.
# Default: "Ziplod <noreply@ziplod.com>"
EMAIL_FROM=

# Domain the Platform Owner mailboxes live on (support@/sales@/mail@).
# Default: ziplod.com
MAILBOX_DOMAIN=

# Client-visible app URL. Only needed if APP_URL / RENDER_EXTERNAL_URL cannot
# be used — APP_URL is checked first everywhere this matters.
# Default: https://ziplod.com
NEXT_PUBLIC_APP_URL=

# Agent presence tuning. Raising the heartbeat interval reduces write load but
# slows how quickly a dropped agent is detected; the offline multiplier is how
# many missed beats mark them offline.
# Defaults: 30000 (30s), 300000 (5m), 3
NEXT_PUBLIC_PRESENCE_HEARTBEAT_MS=
NEXT_PUBLIC_PRESENCE_IDLE_MS=
PRESENCE_OFFLINE_MULTIPLIER=
